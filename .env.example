# Copy to .env and adjust as needed. Sensible defaults match docker-compose.yml.

# Kafka
CONVEYOR_KAFKA_BROKERS=localhost:9092
CONVEYOR_KAFKA_TOPIC=jobs
CONVEYOR_KAFKA_GROUP=conveyor-workers

# Postgres
CONVEYOR_DB_DSN=postgres://conveyor:conveyor@localhost:5432/conveyor?sslmode=disable

# API server
CONVEYOR_API_ADDR=:8080

# Worker
CONVEYOR_WORKER_METRICS_ADDR=:8081
CONVEYOR_WORKER_CONCURRENCY=8
CONVEYOR_MAX_RETRIES=5

# Logging: debug | info | warn | error
CONVEYOR_LOG_LEVEL=info
