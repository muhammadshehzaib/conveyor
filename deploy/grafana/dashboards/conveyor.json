{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Conveyor — Distributed Job Queue",
  "uid": "conveyor-main",
  "tags": ["conveyor", "kafka"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Enqueue rate (jobs/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(conveyor_jobs_enqueued_total[1m]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Throughput (jobs processed/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(conveyor_jobs_processed_total[1m]))" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In-flight jobs",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum(conveyor_jobs_inflight)" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dead-lettered (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "expr": "sum(conveyor_jobs_dead_total)" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Processed jobs/s by result",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "targets": [
        { "refId": "A", "expr": "sum by (result) (rate(conveyor_jobs_processed_total[1m]))", "legendFormat": "{{result}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Job duration (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(conveyor_job_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(conveyor_job_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(conveyor_job_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Retries scheduled/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "rate(conveyor_jobs_retried_total[1m])", "legendFormat": "retries" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Enqueue rate/s by job type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "sum by (type) (rate(conveyor_jobs_enqueued_total[1m]))", "legendFormat": "{{type}}" }
      ]
    }
  ]
}
